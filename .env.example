# ======================================================
# Discord bot identity (required)
# ======================================================
# Create a Discord application/bot, then paste the bot token and application/client ID.
DISCORD_TOKEN=replace-with-your-discord-bot-token
CLIENT_ID=replace-with-your-discord-application-client-id

# Optional: deploy slash commands to one guild for faster updates during testing.
# Leave blank to deploy globally.
GUILD_ID=

# Optional: automatically deploy slash command changes on bot startup.
AUTO_DEPLOY=false

# ======================================================
# Server discovery / control
# ======================================================
# Root folder where direct child folders are auto-discovered as servers.
# Windows example: C:/Servers
# Linux example: /opt/servers
BASE_SERVER_DIR=C:/Servers

# Optional: run only the iDRAC command set and skip server/web/Steam subsystems.
IDRAC_ONLY_MODE=false

# ======================================================
# Bot access control
# ======================================================
# If all of these are blank, everyone is treated as owner for backwards compatibility.
# Use comma-separated Discord user IDs with no spaces.
BOT_OWNER_IDS=
BOT_ADMIN_IDS=
BOT_MOD_IDS=

# Legacy aliases still read by older code paths / auth welcome loop.
OWNER_IDS=
ADMIN_IDS=
MOD_IDS=

# Optional: how often the auth/welcome loop checks owner IDs, in milliseconds.
AUTH_CHECK_INTERVAL_MS=3600000

# ======================================================
# Windows execution bridge
# ======================================================
# Used when the bot needs to execute Windows commands over SSH from another host.
WIN_EXEC_SSH_HOST=
WIN_EXEC_SSH_USER=
WIN_EXEC_TIMEOUT_MS=30000

# ======================================================
# iDRAC / RACADM support
# ======================================================
# Set to "linux" to run racadm over SSH/sshpass, or "windows" to run local racadm.exe.
# Leave blank to disable iDRAC backend commands except status fallback.
IDRAC_PLATFORM=
IDRAC_HOST=
IDRAC_USER=
IDRAC_PASS=

# Required only when IDRAC_PLATFORM=windows.
RACADM_PATH=C:/Program Files/Dell/SysMgt/rac5/racadm.exe

# ======================================================
# Optional web file editor
# ======================================================
WEB_EDITOR_ENABLED=false
WEB_EDITOR_PORT=8787
WEB_EDITOR_PUBLIC_HOST=localhost

# Strongly recommended if WEB_EDITOR_ENABLED=true.
WEB_EDITOR_API_KEY=replace-with-a-long-random-api-key

# Optional comma-separated keys that can view/search but cannot mutate files.
WEB_EDITOR_READ_ONLY_KEYS=

# Optional tree/list depth limit.
WEB_EDITOR_MAX_DEPTH=12

# Set false to disable .webeditor-backups copies before overwriting existing files.
WEB_EDITOR_BACKUP_ON_SAVE=true

# ======================================================
# Minecraft RCON helpers
# ======================================================
# Can be overridden per server with /config set-rcon.
MC_RCON_HOST=127.0.0.1
MC_RCON_PORT=25575
MC_RCON_PASSWORD=

# ======================================================
# Bot self-update script
# ======================================================
SERVER_CONTROL_BOT_REPO_URL=https://github.com/DoctorCheese1/Discord-server-starter.git
SERVER_CONTROL_BOT_UPDATE_BRANCH=main

# ======================================================
# SteamCMD helper scripts
# ======================================================
# Optional path used by generated Steam update.bat scripts.
STEAMCMD_EXE=
