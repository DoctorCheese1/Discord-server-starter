{
  "manifest_version": 3,
  "name": "Spigot Cookie Autofill Detector",
  "version": "1.1.0",
  "description": "Auto-refreshes Spigot cookies every 30 minutes and on popup open, with manual refresh and xf/cf entity grouping.",
  "permissions": ["cookies", "tabs", "storage", "alarms"],
  "host_permissions": ["https://*.spigot.org/*", "https://spigot.org/*", "https://*.spigotmc.org/*", "https://spigotmc.org/*", "https://*.spoigot.org/*", "https://spoigot.org/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Spigot Cookie Autofill Detector",
    "default_popup": "popup.html"
  }
}
